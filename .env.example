# MS365 Graph API - Email sending (set in Cloudflare Pages dashboard for production)
MS365_TENANT_ID=           # Azure AD tenant ID
MS365_CLIENT_ID=           # App registration client ID
MS365_CLIENT_SECRET=       # App registration client secret
MS365_EMAIL=               # Sender email address (e.g., contact@awvaughan.com)

# Cloudflare Turnstile - CAPTCHA protection
TURNSTILE_SECRET_KEY=      # Turnstile secret key from Cloudflare dashboard
